generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS
// ============================================

model User {
  id                BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  firebaseUid       String?        @unique @map("firebase_uid") @db.VarChar(128)
  email             String         @unique @db.VarChar(255)
  emailVerified     Boolean        @default(false) @map("email_verified")
  displayName       String?        @map("display_name") @db.VarChar(255)
  photoUrl          String?        @map("photo_url") @db.VarChar(500)
  phoneNumber       String?        @map("phone_number") @db.VarChar(50)
  phoneVerified     Boolean        @default(false) @map("phone_verified")
  firstName         String?        @map("first_name") @db.VarChar(100)
  lastName          String?        @map("last_name") @db.VarChar(100)
  dateOfBirth       DateTime?      @map("date_of_birth") @db.Date
  gender            Gender?
  bio               String?        @db.Text
  timezone          String         @default("UTC") @db.VarChar(100)
  locale            String         @default("en_US") @map("locale") @db.VarChar(20)
  language          String         @default("en") @db.VarChar(10)
  status            UserStatus     @default(Active)
  isActive          Boolean        @default(true) @map("is_active")
  isSuspended       Boolean        @default(false) @map("is_suspended")
  suspendedUntil    DateTime?      @map("suspended_until")
  suspensionReason  String?        @map("suspension_reason") @db.Text
  lastLoginAt       DateTime?      @map("last_login_at")
  lastLoginIp       String?        @map("last_login_ip") @db.VarChar(45)
  lastActivityAt    DateTime?      @map("last_activity_at")
  passwordChangedAt DateTime?      @map("password_changed_at")
  twoFactorEnabled  Boolean        @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?        @map("two_factor_secret") @db.VarChar(255)
  tenantId          BigInt?        @map("tenant_id") @db.UnsignedBigInt
  metadata          String?        @db.Text
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime?      @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  password          String?        @map("password") @db.VarChar(255)
  auditLogs         AuditLog[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  roles             UserRole[]
  sessions          UserSession[]
  userSettings      UserSettings?
  exploreProfile    ExploreUser?   @relation("UserExploreProfile")

  @@index([firebaseUid], map: "idx_firebase_uid")
  @@index([email], map: "idx_email")
  @@index([status], map: "idx_status")
  @@index([isActive], map: "idx_is_active")
  @@index([tenantId], map: "idx_tenant_id")
  @@index([lastLoginAt], map: "idx_last_login_at")
  @@index([createdAt], map: "idx_created_at")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("auth_users")
}

model Role {
  id          Int              @id @default(autoincrement()) @db.UnsignedInt
  name        String           @unique @db.VarChar(100)
  slug        String           @unique @db.VarChar(100)
  description String?          @db.Text
  isSystem    Boolean          @default(false) @map("is_system")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime?        @updatedAt @map("updated_at")
  permissions RolePermission[]
  users       UserRole[]

  @@index([slug], map: "idx_slug")
  @@index([isActive], map: "idx_is_active")
  @@map("auth_roles")
}

model Permission {
  id          Int              @id @default(autoincrement()) @db.UnsignedInt
  name        String           @unique @db.VarChar(100)
  slug        String           @unique @db.VarChar(100)
  resource    String           @db.VarChar(100)
  action      String           @db.VarChar(50)
  description String?          @db.Text
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime?        @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@index([slug], map: "idx_slug")
  @@index([resource], map: "idx_resource")
  @@index([action], map: "idx_action")
  @@index([isActive], map: "idx_is_active")
  @@map("auth_permissions")
}

model UserRole {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt    @map("user_id") @db.UnsignedBigInt
  roleId     Int       @map("role_id") @db.UnsignedInt
  assignedBy BigInt?   @map("assigned_by") @db.UnsignedBigInt
  assignedAt DateTime  @default(now()) @map("assigned_at")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], name: "uq_user_role")
  @@index([userId], map: "idx_user_id")
  @@index([roleId], map: "idx_role_id")
  @@index([isActive], map: "idx_is_active")
  @@index([expiresAt], map: "idx_expires_at")
  @@map("auth_user_roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement()) @db.UnsignedInt
  roleId       Int        @map("role_id") @db.UnsignedInt
  permissionId Int        @map("permission_id") @db.UnsignedInt
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], name: "uq_role_permission")
  @@index([roleId], map: "idx_role_id")
  @@index([permissionId], map: "idx_permission_id")
  @@map("auth_role_permissions")
}

model UserSession {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId         BigInt    @map("user_id") @db.UnsignedBigInt
  sessionToken   String    @unique @map("session_token") @db.VarChar(255)
  refreshToken   String?   @unique @map("refresh_token") @db.VarChar(255)
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.VarChar(500)
  deviceType     String?   @map("device_type") @db.VarChar(50)
  deviceId       String?   @map("device_id") @db.VarChar(255)
  location       String?   @db.VarChar(255)
  isActive       Boolean   @default(true) @map("is_active")
  expiresAt      DateTime  @map("expires_at")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([sessionToken], map: "idx_session_token")
  @@index([refreshToken], map: "idx_refresh_token")
  @@index([isActive], map: "idx_is_active")
  @@index([expiresAt], map: "idx_expires_at")
  @@map("auth_user_sessions")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  isRevoked Boolean   @default(false) @map("is_revoked")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([token], map: "idx_token")
  @@index([expiresAt], map: "idx_expires_at")
  @@index([isRevoked], map: "idx_is_revoked")
  @@map("auth_refresh_tokens")
}

model UserSettings {
  id                 BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  userId             BigInt            @unique @map("user_id") @db.UnsignedBigInt
  emailNotifications Boolean           @default(true) @map("email_notifications")
  pushNotifications  Boolean           @default(true) @map("push_notifications")
  smsNotifications   Boolean           @default(false) @map("sms_notifications")
  profileVisibility  ProfileVisibility @default(Public) @map("profile_visibility")
  showEmail          Boolean           @default(false) @map("show_email")
  showPhone          Boolean           @default(false) @map("show_phone")
  theme              String            @default("light") @db.VarChar(20)
  language           String            @default("en") @db.VarChar(10)
  timezone           String            @default("UTC") @db.VarChar(100)
  dateFormat         String            @default("YYYY-MM-DD") @map("date_format") @db.VarChar(20)
  timeFormat         String            @default("24h") @map("time_format") @db.VarChar(10)
  itemsPerPage       Int               @default(20) @map("items_per_page")
  autoSave           Boolean           @default(true) @map("auto_save")
  customSettings     String?           @map("custom_settings") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime?         @updatedAt @map("updated_at")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_user_settings")
}

model AuditLog {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt?       @map("user_id") @db.UnsignedBigInt
  action      String        @db.VarChar(100)
  resource    String?       @db.VarChar(100)
  resourceId  String?       @map("resource_id") @db.VarChar(255)
  description String?       @db.Text
  ipAddress   String?       @map("ip_address") @db.VarChar(45)
  userAgent   String?       @map("user_agent") @db.VarChar(500)
  metadata    String?       @db.Text
  severity    AuditSeverity @default(Info)
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User?         @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_user_id")
  @@index([action], map: "idx_action")
  @@index([resource], map: "idx_resource")
  @@index([severity], map: "idx_severity")
  @@index([createdAt], map: "idx_created_at")
  @@map("auth_audit_logs")
}

model Notification {
  id        BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt           @map("user_id") @db.UnsignedBigInt
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  metadata  String?          @db.Text
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([type], map: "idx_type")
  @@index([isRead], map: "idx_is_read")
  @@index([createdAt], map: "idx_created_at")
  @@map("auth_notifications")
}

// ============================================
// FINANCE MODELS
// ============================================

model FinanceBank {
  id            Int              @id @default(autoincrement()) @db.UnsignedInt
  name          String           @db.VarChar(255)
  code          String?          @db.VarChar(50)
  accountNumber String?          @map("account_number") @db.VarChar(100)
  routingNumber String?          @map("routing_number") @db.VarChar(50)
  branch        String?          @db.VarChar(255)
  contactPerson String?          @map("contact_person") @db.VarChar(255)
  contactPhone  String?          @map("contact_phone") @db.VarChar(50)
  contactEmail  String?          @map("contact_email") @db.VarChar(255)
  website       String?          @db.VarChar(255)
  notes         String?          @db.Text
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime?        @updatedAt @map("updated_at")
  accounts      FinanceAccount[]

  @@index([name], map: "idx_name")
  @@index([code], map: "idx_code")
  @@index([isActive], map: "idx_is_active")
  @@map("finance_banks")
}

model FinanceAccount {
  id             Int                  @id @default(autoincrement()) @db.UnsignedInt
  bankId         Int                  @map("bank_id") @db.UnsignedInt
  name           String               @db.VarChar(255)
  accountNumber  String?              @map("account_number") @db.VarChar(100)
  accountType    AccountType          @default(Checking) @map("account_type")
  currency       String               @default("USD") @db.VarChar(10)
  initialBalance Decimal              @default(0.00) @map("initial_balance") @db.Decimal(15, 2)
  currentBalance Decimal              @default(0.00) @map("current_balance") @db.Decimal(15, 2)
  notes          String?              @db.Text
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime?            @updatedAt @map("updated_at")
  bank           FinanceBank          @relation(fields: [bankId], references: [id])
  transactions   FinanceTransaction[] @relation("AccountTransactions")
  transferTo     FinanceTransaction[] @relation("TransferToAccount")

  @@index([bankId], map: "idx_bank_id")
  @@index([accountType], map: "idx_account_type")
  @@index([isActive], map: "idx_is_active")
  @@map("finance_accounts")
}

model FinanceCategory {
  id           Int                  @id @default(autoincrement()) @db.UnsignedInt
  name         String               @db.VarChar(255)
  type         CategoryType
  parentId     Int?                 @map("parent_id") @db.UnsignedInt
  description  String?              @db.Text
  color        String?              @db.VarChar(7)
  icon         String?              @db.VarChar(50)
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @default(now()) @updatedAt @map("updated_at")
  parent       FinanceCategory?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     FinanceCategory[]    @relation("CategoryHierarchy")
  transactions FinanceTransaction[]

  @@unique([name, type], name: "uq_category_name_type")
  @@index([type], map: "idx_type")
  @@index([parentId], map: "idx_parent_id")
  @@index([isActive], map: "idx_is_active")
  @@map("finance_categories")
}

model FinanceTransaction {
  id                  BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  transactionType     TransactionType  @map("transaction_type")
  accountId           Int              @map("account_id") @db.UnsignedInt
  transferToAccountId Int?             @map("transfer_to_account_id") @db.UnsignedInt
  categoryId          Int?             @map("category_id") @db.UnsignedInt
  amount              Decimal          @db.Decimal(15, 2)
  balanceAfter        Decimal          @map("balance_after") @db.Decimal(15, 2)
  description         String?          @db.Text
  referenceNumber     String?          @map("reference_number") @db.VarChar(100)
  transactionDate     DateTime         @map("transaction_date") @db.Date
  notes               String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime?        @updatedAt @map("updated_at")
  account             FinanceAccount   @relation("AccountTransactions", fields: [accountId], references: [id])
  category            FinanceCategory? @relation(fields: [categoryId], references: [id])
  transferToAccount   FinanceAccount?  @relation("TransferToAccount", fields: [transferToAccountId], references: [id], onDelete: Restrict)

  @@index([accountId], map: "idx_account_id")
  @@index([transferToAccountId], map: "idx_transfer_to_account_id")
  @@index([categoryId], map: "idx_category_id")
  @@index([transactionType], map: "idx_transaction_type")
  @@index([transactionDate], map: "idx_transaction_date")
  @@index([createdAt], map: "idx_created_at")
  @@map("finance_transactions")
}

// ============================================
// SCHOOL MODELS
// ============================================

model SchoolGrade {
  id          Int             @id @default(autoincrement()) @db.UnsignedInt
  name        String          @db.VarChar(100)
  level       Int
  description String?         @db.Text
  status      GradeStatus     @default(Active)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime?       @updatedAt @map("updated_at")
  rooms       SchoolRoom[]
  students    SchoolStudent[]

  @@unique([name, level], name: "uq_grade_name_level")
  @@map("school_grades")
}

model SchoolRoom {
  id        Int             @id @default(autoincrement()) @db.UnsignedInt
  gradeId   Int             @map("grade_id") @db.UnsignedInt
  name      String          @db.VarChar(100)
  capacity  Int?
  location  String?         @db.VarChar(100)
  teacherId Int?            @map("teacher_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime?       @updatedAt @map("updated_at")
  grade     SchoolGrade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  students  SchoolStudent[]

  @@index([gradeId], map: "idx_rooms_grade")
  @@map("school_rooms")
}

model SchoolSetting {
  id                 Int       @id @default(autoincrement()) @db.UnsignedInt
  schoolCode         String?   @unique @map("school_code") @db.VarChar(50)
  schoolName         String    @map("school_name") @db.VarChar(255)
  shortName          String?   @map("short_name") @db.VarChar(100)
  addressLine1       String?   @map("address_line1") @db.VarChar(255)
  addressLine2       String?   @map("address_line2") @db.VarChar(255)
  city               String?   @db.VarChar(100)
  state              String?   @db.VarChar(100)
  postalCode         String?   @map("postal_code") @db.VarChar(20)
  country            String?   @db.VarChar(100)
  phone              String?   @db.VarChar(50)
  fax                String?   @db.VarChar(50)
  email              String?   @db.VarChar(255)
  website            String?   @db.VarChar(255)
  contactPersonName  String?   @map("contact_person_name") @db.VarChar(255)
  contactPersonPhone String?   @map("contact_person_phone") @db.VarChar(50)
  contactPersonEmail String?   @map("contact_person_email") @db.VarChar(255)
  logoUrl            String?   @map("logo_url") @db.VarChar(255)
  faviconUrl         String?   @map("favicon_url") @db.VarChar(255)
  timezone           String    @default("UTC") @db.VarChar(100)
  locale             String    @default("en_US") @db.VarChar(20)
  academicYearStart  DateTime? @map("academic_year_start") @db.Date
  academicYearEnd    DateTime? @map("academic_year_end") @db.Date
  defaultLanguage    String    @default("en") @map("default_language") @db.VarChar(20)
  defaultCurrency    String?   @map("default_currency") @db.VarChar(10)
  registrationNumber String?   @map("registration_number") @db.VarChar(100)
  taxId              String?   @map("tax_id") @db.VarChar(100)
  smsEnabled         Boolean   @default(false) @map("sms_enabled")
  smsProvider        String?   @map("sms_provider") @db.VarChar(100)
  extra              String?   @db.Text
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  @@map("school_settings")
}

model SchoolStudent {
  id            Int           @id @default(autoincrement()) @db.UnsignedInt
  nis           String        @unique @db.VarChar(50)
  name          String        @db.VarChar(255)
  gender        Gender        @default(Male)
  dateOfBirth   DateTime?     @map("date_of_birth") @db.Date
  grade         Int?          @db.UnsignedInt
  room          Int?          @db.UnsignedInt
  parentName    String?       @map("parent_name") @db.VarChar(255)
  parentPhone   String?       @map("parent_phone") @db.VarChar(50)
  address       String?       @db.Text
  status        StudentStatus @default(Active)
  qrHash        String?       @unique @map("qr_hash") @db.VarChar(128)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime?     @updatedAt @map("updated_at")
  gradeRelation SchoolGrade?  @relation(fields: [grade], references: [id])
  roomRelation  SchoolRoom?   @relation(fields: [room], references: [id])

  @@index([grade], map: "idx_grade")
  @@index([room], map: "idx_room")
  @@map("school_students")
}

model SchoolSubject {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  code         String      @unique @db.VarChar(20)
  name         String      @db.VarChar(100)
  description  String?     @db.Text
  grade        Int
  semester     Int
  type         SubjectType @default(mandatory)
  hoursPerWeek Int         @default(0) @map("hours_per_week")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  @@map("school_subjects")
}

model SchoolTeacher {
  id       Int           @id @default(autoincrement())
  name     String        @db.VarChar(255)
  degree   String?       @db.VarChar(100)
  email    String        @db.VarChar(255)
  subject  String        @db.VarChar(255)
  nip      String        @db.VarChar(100)
  gender   TeacherGender @default(Male)
  status   TeacherStatus @default(Active)
  jobType  JobType       @default(Permanent) @map("job_type")
  joinDate DateTime?     @map("join_date") @db.Date
  avatar   String?       @db.VarChar(255)

  @@map("school_teachers")
}

// ============================================
// ENGINEERING MODELS
// ============================================

model EngineeringWiki {
  id               BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  title            String       @db.VarChar(255)
  customerName     String?      @map("customer_name") @db.VarChar(255)
  category         WikiCategory @default(note)
  brand            String?      @db.VarChar(255)
  deviceType       String?      @map("device_type") @db.VarChar(255)
  model            String?      @db.VarChar(255)
  serialNumber     String?      @map("serial_number") @db.VarChar(255)
  firmwareVersion  String?      @map("firmware_version") @db.VarChar(255)
  hardwareVersion  String?      @map("hardware_version") @db.VarChar(255)
  symptom          String?      @db.Text
  symptomFile      String?      @map("symptom_file") @db.VarChar(500)
  symptomImage     String?      @map("symptom_image") @db.VarChar(500)
  rootCause        String?      @map("root_cause") @db.Text
  rootCauseFile    String?      @map("root_cause_file") @db.VarChar(500)
  rootCauseImage   String?      @map("root_cause_image") @db.VarChar(500)
  solution         String?      @db.Text
  solutionFile     String?      @map("solution_file") @db.VarChar(500)
  solutionImage    String?      @map("solution_image") @db.VarChar(500)
  actionTaken      String?      @map("action_taken") @db.Text
  actionTakenFile  String?      @map("action_taken_file") @db.VarChar(500)
  actionTakenImage String?      @map("action_taken_image") @db.VarChar(500)
  status           WikiStatus   @default(open)
  priority         WikiPriority @default(medium)
  referenceDoc     String?      @map("reference_doc") @db.VarChar(255)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime?    @updatedAt @map("updated_at")

  @@index([category], map: "idx_category")
  @@index([status], map: "idx_status")
  @@index([priority], map: "idx_priority")
  @@index([brand], map: "idx_brand")
  @@index([deviceType], map: "idx_device_type")
  @@index([createdAt], map: "idx_created_at")
  @@map("engineering_wikis")
}

model EngineeringTask {
  id                       BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  title                    String                      @db.VarChar(255)
  description              String?                     @db.Text
  category                 TaskCategory
  priority                 TaskPriority
  status                   TaskStatus
  assignedTo               BigInt?                     @map("assigned_to") @db.UnsignedBigInt
  createdBy                BigInt?                     @map("created_by") @db.UnsignedBigInt
  assetId                  BigInt?                     @map("asset_id") @db.UnsignedBigInt
  dueDate                  DateTime?                   @map("due_date") @db.Date
  recurrencePattern        String?                     @map("recurrence_pattern") @db.VarChar(100)
  parentTaskId             BigInt?                     @map("parent_task_id") @db.UnsignedBigInt
  tags                     String?                     @db.VarChar(500)
  requiresPhoto            Boolean                     @default(false) @map("requires_photo")
  requiresGps              Boolean                     @default(false) @map("requires_gps")
  estimatedDurationMinutes Int?                        @map("estimated_duration_minutes")
  actualDurationMinutes    Int?                        @map("actual_duration_minutes")
  completedAt              DateTime?                   @map("completed_at")
  createdAt                DateTime                    @default(now()) @map("created_at")
  updatedAt                DateTime?                   @updatedAt @map("updated_at")
  asset                    EngineeringAsset?           @relation(fields: [assetId], references: [id])
  logs                     EngineeringTaskLog[]
  attachments              EngineeringTaskAttachment[]
  comments                 EngineeringTaskComment[]

  @@index([category], map: "idx_category")
  @@index([status], map: "idx_status")
  @@index([priority], map: "idx_priority")
  @@index([assignedTo], map: "idx_assigned_to")
  @@index([createdBy], map: "idx_created_by")
  @@index([assetId], map: "idx_asset_id")
  @@index([dueDate], map: "idx_due_date")
  @@index([parentTaskId], map: "idx_parent_task_id")
  @@index([createdAt], map: "idx_created_at")
  @@index([status, category], map: "idx_status_category")
  @@map("engineering_tasks")
}

model EngineeringTaskLog {
  id              BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  taskId          BigInt         @map("task_id") @db.UnsignedBigInt
  userId          BigInt?        @map("user_id") @db.UnsignedBigInt
  actionType      TaskActionType @map("action_type")
  oldStatus       TaskStatus?    @map("old_status")
  newStatus       TaskStatus?    @map("new_status")
  updateDetails   String?        @map("update_details") @db.Text
  comment         String?        @db.Text
  photoUrl        String?        @map("photo_url") @db.VarChar(500)
  locationTag     String?        @map("location_tag") @db.VarChar(255)
  locationAddress String?        @map("location_address") @db.VarChar(500)
  metadata        String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  task            EngineeringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "idx_task_id")
  @@index([userId], map: "idx_user_id")
  @@index([actionType], map: "idx_action_type")
  @@index([createdAt], map: "idx_created_at")
  @@map("engineering_task_logs")
}

model EngineeringAsset {
  id                   BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  name                 String            @db.VarChar(255)
  assetCode            String?           @unique @map("asset_code") @db.VarChar(100)
  type                 AssetType
  brand                String?           @db.VarChar(100)
  model                String?           @db.VarChar(100)
  serialNumber         String?           @map("serial_number") @db.VarChar(100)
  location             String?           @db.VarChar(255)
  department           String?           @db.VarChar(100)
  status               AssetStatus
  description          String?           @db.Text
  purchaseDate         DateTime?         @map("purchase_date") @db.Date
  warrantyExpiry       DateTime?         @map("warranty_expiry") @db.Date
  lastMaintenanceDate  DateTime?         @map("last_maintenance_date") @db.Date
  nextMaintenanceDate  DateTime?         @map("next_maintenance_date") @db.Date
  photoUrl             String?           @map("photo_url") @db.VarChar(500)
  metadata             String?           @db.Text
  isActive             Boolean           @default(true) @map("is_active")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime?         @updatedAt @map("updated_at")
  tasks                EngineeringTask[]

  @@index([type], map: "idx_type")
  @@index([status], map: "idx_status")
  @@index([location], map: "idx_location")
  @@index([department], map: "idx_department")
  @@index([isActive], map: "idx_is_active")
  @@map("engineering_assets")
}

model EngineeringTaskAttachment {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  taskId         BigInt          @map("task_id") @db.UnsignedBigInt
  fileName       String          @map("file_name") @db.VarChar(255)
  filePath       String          @map("file_path") @db.VarChar(500)
  fileType       String?         @map("file_type") @db.VarChar(50)
  fileSize       Int?            @map("file_size")
  attachmentType AttachmentType? @map("attachment_type")
  description    String?         @db.VarChar(500)
  uploadedBy     BigInt?         @map("uploaded_by") @db.UnsignedBigInt
  createdAt      DateTime        @default(now()) @map("created_at")
  task           EngineeringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "idx_task_id")
  @@index([attachmentType], map: "idx_attachment_type")
  @@index([uploadedBy], map: "idx_uploaded_by")
  @@map("engineering_task_attachments")
}

model EngineeringTaskComment {
  id         BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  taskId     BigInt          @map("task_id") @db.UnsignedBigInt
  userId     BigInt?         @map("user_id") @db.UnsignedBigInt
  comment    String          @db.Text
  isInternal Boolean         @default(false) @map("is_internal")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime?       @updatedAt @map("updated_at")
  task       EngineeringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "idx_task_id")
  @@index([userId], map: "idx_user_id")
  @@index([createdAt], map: "idx_created_at")
  @@map("engineering_task_comments")
}

model EngineeringTaskTemplate {
  id                       BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name                     String       @db.VarChar(255)
  description              String?      @db.Text
  category                 TaskCategory
  priority                 TaskPriority @default(normal)
  estimatedDurationMinutes Int?         @map("estimated_duration_minutes")
  requiresPhoto            Boolean      @default(false) @map("requires_photo")
  requiresGps              Boolean      @default(false) @map("requires_gps")
  checklistItems           String?      @map("checklist_items") @db.Text
  tags                     String?      @db.VarChar(500)
  isActive                 Boolean      @default(true) @map("is_active")
  createdBy                BigInt?      @map("created_by") @db.UnsignedBigInt
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime?    @updatedAt @map("updated_at")

  @@index([category], map: "idx_category")
  @@index([isActive], map: "idx_is_active")
  @@map("engineering_task_templates")
}

model EngineeringDailyTaskReset {
  id              BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  resetDate       DateTime          @unique @map("reset_date") @db.Date
  tasksResetCount Int               @default(0) @map("tasks_reset_count")
  executedAt      DateTime          @default(now()) @map("executed_at")
  status          TaskResetStatus   @default(success)
  errorMessage    String?           @map("error_message") @db.Text

  @@index([executedAt], map: "idx_executed_at")
  @@map("engineering_daily_task_resets")
}


// ============================================
// SOCIAL/EXPLORE MODELS
// ============================================

model ExploreUser {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  userId         BigInt          @unique @map("user_id") @db.UnsignedBigInt
  username       String          @unique @db.VarChar(50)
  displayName    String          @map("display_name") @db.VarChar(100)
  email          String?         @unique @db.VarChar(255)
  bio            String?         @db.Text
  avatar         String?         @db.VarChar(500)
  isPrivate      Boolean         @default(false) @map("is_private")
  isVerified     Boolean         @default(false) @map("is_verified")
  isActive       Boolean         @default(true) @map("is_active")
  followersCount Int             @default(0) @map("followers_count")
  followingCount Int             @default(0) @map("following_count")
  postsCount     Int             @default(0) @map("posts_count")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @updatedAt @map("updated_at")
  authUser       User            @relation("UserExploreProfile", fields: [userId], references: [id], onDelete: Cascade)
  followers      ExploreFollow[] @relation("UserFollowers")
  following      ExploreFollow[] @relation("UserFollowing")
  likes          ExploreLike[]
  posts          ExplorePost[]   @relation("UserPosts")

  @@index([userId], map: "idx_user_id")
  @@index([username], map: "idx_username")
  @@index([email], map: "idx_email")
  @@index([isActive], map: "idx_is_active")
  @@index([isPrivate], map: "idx_is_private")
  @@index([createdAt], map: "idx_created_at")
  @@map("explore_users")
}

model ExplorePost {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt        @map("user_id") @db.UnsignedBigInt
  content      String        @db.Text
  mediaUrl     String?       @map("media_url") @db.VarChar(500)
  replyToId    BigInt?       @map("reply_to_id") @db.UnsignedBigInt
  repostOfId   BigInt?       @map("repost_of_id") @db.UnsignedBigInt
  isDeleted    Boolean       @default(false) @map("is_deleted")
  isPrivate    Boolean       @default(false) @map("is_private")
  likesCount   Int           @default(0) @map("likes_count")
  repliesCount Int           @default(0) @map("replies_count")
  repostsCount Int           @default(0) @map("reposts_count")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime?     @updatedAt @map("updated_at")
  likes        ExploreLike[]
  replyTo      ExplorePost?  @relation("PostReplies", fields: [replyToId], references: [id], onDelete: Cascade)
  replies      ExplorePost[] @relation("PostReplies")
  repostOf     ExplorePost?  @relation("PostReposts", fields: [repostOfId], references: [id], onDelete: Cascade)
  reposts      ExplorePost[] @relation("PostReposts")
  user         ExploreUser   @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id")
  @@index([replyToId], map: "idx_reply_to_id")
  @@index([repostOfId], map: "idx_repost_of_id")
  @@index([isDeleted], map: "idx_is_deleted")
  @@index([isPrivate], map: "idx_is_private")
  @@index([createdAt], map: "idx_created_at")
  @@map("explore_posts")
}

model ExploreFollow {
  id          BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  followerId  BigInt      @map("follower_id") @db.UnsignedBigInt
  followingId BigInt      @map("following_id") @db.UnsignedBigInt
  createdAt   DateTime    @default(now()) @map("created_at")
  follower    ExploreUser @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   ExploreUser @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId], name: "uq_follower_following")
  @@index([followerId], map: "idx_follower_id")
  @@index([followingId], map: "idx_following_id")
  @@index([createdAt], map: "idx_created_at")
  @@map("explore_follows")
}

model ExploreLike {
  id        BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt      @map("user_id") @db.UnsignedBigInt
  postId    BigInt      @map("post_id") @db.UnsignedBigInt
  createdAt DateTime    @default(now()) @map("created_at")
  post      ExplorePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      ExploreUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], name: "uq_user_post_like")
  @@index([userId], map: "idx_user_id")
  @@index([postId], map: "idx_post_id")
  @@index([createdAt], map: "idx_created_at")
  @@map("explore_likes")
}

