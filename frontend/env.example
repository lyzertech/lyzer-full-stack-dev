# =============================================================================
# API switch — satu baris untuk ganti local / production
# =============================================================================
# Salin ke .env.local untuk development:
#   cp env.example .env.local
#
# Production deploy: salin env.production.example → .env.production
#   (atau set variabel yang sama di CI sebelum `npm run build`)
#
# Semua URL API dibaca lewat lib/api-config.js — jangan hardcode di komponen.

# --- SWITCH ---
# local = Laravel localhost:8000
# production = api.lyzer.my.id (frontend dev → live API, set USE_RELATIVE_API=true)
NEXT_PUBLIC_API_MODE=production

# -----------------------------------------------------------------------------
# Local — Laravel di mesin Anda (`php artisan serve`, port 8000)
# -----------------------------------------------------------------------------
LARAVEL_API_URL_LOCAL=http://localhost:8000
NEXT_PUBLIC_API_URL_LOCAL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Production — dipakai saat NEXT_PUBLIC_API_MODE=production atau `next build`
# (nilai default juga ada di lib/api-config.js jika env kosong)
# -----------------------------------------------------------------------------
LARAVEL_API_URL_PRODUCTION=https://api.lyzer.my.id
NEXT_PUBLIC_API_URL_PRODUCTION=https://api.lyzer.my.id/api/v1

# Wajib untuk `next dev` + API production (hindari CORS / session error):
NEXT_PUBLIC_USE_RELATIVE_API=true

# Node
NODE_ENV=development
