# Salin ke .env.production sebelum `npm run build` (file .env.production di-ignore git)
#   cp env.production.example .env.production
#
# Atau set variabel ini di CI/hosting — wajib untuk production build.

NEXT_PUBLIC_API_MODE=production

LARAVEL_API_URL_PRODUCTION=https://api.lyzer.my.id
NEXT_PUBLIC_API_URL_PRODUCTION=https://api.lyzer.my.id/api/v1

# Hanya jika frontend mem-proxy /api/v1 ke Laravel (same-origin):
# NEXT_PUBLIC_USE_RELATIVE_API=true
